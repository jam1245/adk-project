# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Set these to switch between providers. Only change what you need.
# The default (no env vars set) uses Anthropic Claude 3 Haiku.

# LLM model string (LiteLLM format: "provider/model-name")
# Examples:
#   anthropic/claude-3-haiku-20240307   (default)
#   openai/gpt-4o
#   openai/your-model-name              (for OpenAI-compatible endpoints)
LLM_MODEL=anthropic/claude-3-haiku-20240307

# Custom API base URL (only needed for internal/self-hosted endpoints)
# LLM_API_BASE=

# API key override (if not set, LiteLLM uses provider-specific env vars below)
# LLM_API_KEY=

# SSL verification (set to "false" for internal endpoints with self-signed certs)
# LLM_SSL_VERIFY=true

# =============================================================================
# Provider-specific API keys (used when LLM_API_KEY is not set)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# External Assistant Integration (risk_agent)
# =============================================================================
# Bearer token for the external Assistants API.
# Falls back to OPENAI_API_KEY if EXT_ASSISTANT_API_KEY is not set.
# EXT_ASSISTANT_API_KEY=your-bearer-token-here

# Organization name (OpenAI-Organization header)
# EXT_ASSISTANT_ORG=

# External assistant base URL
# EXT_ASSISTANT_API_BASE=https://your-endpoint/v1

# Assistant ID (pre-built assistant with system prompt + vector store)
# EXT_ASSISTANT_ID=your-assistant-id-here

# SSL verification — "false" for endpoints with self-signed certs
# EXT_ASSISTANT_SSL_VERIFY=false

# Poll tuning (seconds)
# EXT_ASSISTANT_POLL_INTERVAL=2
# EXT_ASSISTANT_POLL_TIMEOUT=120

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
MAX_REFINEMENT_ITERATIONS=3

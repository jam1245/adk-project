# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Set these to switch between providers. Only change what you need.
# The default (no env vars set) uses Anthropic Claude 3 Haiku.

# LLM model string (LiteLLM format: "provider/model-name")
# Examples:
#   anthropic/claude-3-haiku-20240307   (default)
#   openai/gpt-4o
#   openai/your-model-name              (for OpenAI-compatible endpoints)
LLM_MODEL=anthropic/claude-3-haiku-20240307

# Custom API base URL (only needed for internal/self-hosted LLM endpoints)
# LLM_API_BASE=

# API key override (if not set, LiteLLM uses provider-specific env vars below)
# LLM_API_KEY=

# SSL verification (set to "false" for internal endpoints with self-signed certs)
# LLM_SSL_VERIFY=true

# =============================================================================
# Provider-specific API keys (used when LLM_API_KEY is not set)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# LM Platform — Internal Assistant API
# =============================================================================
# Shared connection settings used by ALL four sub-agent assistants.
# These replace the legacy EXT_ASSISTANT_* vars.

# Base URL for the OpenAI-compatible Assistants API on your internal LM platform
# LM_PLATFORM_BASE_URL=https://your-internal-platform-url/v1

# Bearer token for the LM platform API
# LM_PLATFORM_API_KEY=your-api-key

# SSL verification — set to "false" for endpoints with self-signed certs
# EXT_ASSISTANT_SSL_VERIFY=false

# OpenAI-Organization header (optional, leave blank if not required)
# EXT_ASSISTANT_ORG=

# Poll tuning (seconds) — increase TIMEOUT for slow platforms
# EXT_ASSISTANT_POLL_INTERVAL=2
# EXT_ASSISTANT_POLL_TIMEOUT=120

# Retry count for transient failures (timeouts, 5xx, connection errors)
# EXT_ASSISTANT_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# Per-assistant IDs — get these from your LM platform dashboard
# Each sub-agent calls a different pre-built assistant with its own system
# instructions and vector store.
# -----------------------------------------------------------------------------

# PM Agent → PM Assistant (leadership briefs, schedules, executive summaries)
# PM_ASSISTANT_ID=your-pm-assistant-id

# Risk Agent → RIO Assistant (Risk / Issue / Opportunity analysis, 5x5 matrix)
# RISK_ASSISTANT_ID=your-rio-assistant-id

# RCCA Agent → RCCA Assistant (Root Cause & Corrective Action, 5 Whys, 8D)
# RCCA_ASSISTANT_ID=your-rcca-assistant-id

# CAM Agent → CAM Assistant (EVM, CPI/SPI, EAC, cost variance)
# CAM_ASSISTANT_ID=your-cam-assistant-id

# -----------------------------------------------------------------------------
# Legacy single-assistant var (EXT_ASSISTANT_ID)
# Only used by src/agents/risk_agent.py (old tool-based pattern).
# The new adk_agents/* wrappers use the per-agent IDs above.
# -----------------------------------------------------------------------------
# EXT_ASSISTANT_API_KEY=your-bearer-token-here   (falls back to LM_PLATFORM_API_KEY)
# EXT_ASSISTANT_API_BASE=https://your-endpoint/v1  (falls back to LM_PLATFORM_BASE_URL)
# EXT_ASSISTANT_ID=your-legacy-single-assistant-id

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
MAX_REFINEMENT_ITERATIONS=3
